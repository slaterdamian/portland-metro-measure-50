# ---- Derived geodata ----------------------------------------------------
# Regenerate with src/10_extract.py .. src/30_render_3d.py
data/interim/*
!data/interim/.gitkeep
data/processed/*.geojson

# Keep small derived summaries under version control:
!data/processed/phase1_summary.json

# ---- Rendered outputs ---------------------------------------------------
outputs/figures/*
